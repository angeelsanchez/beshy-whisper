{
  "name": "beshy-whisper",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "dev": "next dev -p 4000",
    "build": "next build",
    "start": "next start -p 4000",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "backup:simple": "node scripts/backup-simple.js",
    "backup:full": "node scripts/backup.js",
    "backup:pg": "node scripts/backup-pg.js",
    "restore": "node scripts/restore.js",
    "prepare": "husky",
    "lint:fix": "eslint src/ --fix"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --no-warn-ignored --max-warnings=0"
    ]
  },
  "dependencies": {
    "@sentry/nextjs": "^10.38.0",
    "@supabase/supabase-js": "^2.93.3",
    "bcryptjs": "^2.4.3",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "dotenv": "^16.6.1",
    "fs-extra": "^11.3.3",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.563.0",
    "next": "^15.5.12",
    "next-auth": "^4.24.13",
    "ora": "^5.4.1",
    "pg": "^8.17.2",
    "puppeteer": "^24.15.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-google-recaptcha-v3": "^1.11.0",
    "recharts": "^3.7.0",
    "web-push": "^3.6.7",
    "zod": "^3.25.76"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@sentry/cli",
      "core-js",
      "esbuild",
      "puppeteer",
      "sharp",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.0",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/web-push": "^3.6.4",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.23",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.5.11",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
